# Imagem publicada pelo GitHub Actions no GitHub Container Registry.
APP_IMAGE=ghcr.io/cledson96/lanchonete:latest

# Porta local em que o Nginx da VPS vai acessar o container Next.js.
APP_HOST_PORT=127.0.0.1:3001

# Banco Postgres ja criado na VPS.
# Se o Postgres estiver instalado no host da VPS, use host.docker.internal.
DATABASE_URL=postgresql://lanchonete_app:troque-esta-senha@host.docker.internal:5432/lanchonete_prod?schema=public
USE_LOCAL_DB_ON_START=true

# Runtime Next.js.
NODE_ENV=production
APP_AUTH_SECRET=gere-um-segredo-longo-com-openssl-rand-base64-32
APP_URL=https://lanchonete.exemplo.com
NEXT_PUBLIC_SITE_URL=https://lanchonete.exemplo.com

# Usuario admin criado/atualizado pelo seed.
ADMIN_EMAIL=admin@lanchonete.exemplo.com
ADMIN_PHONE=5599999999999
ADMIN_PASSWORD=troque-esta-senha-admin

# WhatsApp.
NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/5599999999999
WHATSAPP_SESSION_PATH=.runtime/whatsapp-session
WHATSAPP_HEADLESS=true
WHATSAPP_CLIENT_NAME=lanchonete-familia
WHATSAPP_ALLOWED_COUNTRY_CODE=55
WHATSAPP_BOT_ENABLED=true

# Loja.
STORE_PIX_KEY=sua-chave-pix
ROUTING_SERVICE_URL=https://router.project-osrm.org
ROUTING_DISTANCE_SAFETY_FACTOR=1.08
