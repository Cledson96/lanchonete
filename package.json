{
  "name": "lanchonete",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma da lanchonete",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src prisma.config.ts prisma/seed.ts next.config.ts eslint.config.mjs --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "prisma:format": "DOTENV_CONFIG_PATH=.env.local prisma format --schema=prisma/schema.prisma",
    "prisma:validate": "DOTENV_CONFIG_PATH=.env.local prisma validate --schema=prisma/schema.prisma",
    "prisma:generate": "DOTENV_CONFIG_PATH=.env.local prisma generate --schema=prisma/schema.prisma",
    "prisma:seed": "DOTENV_CONFIG_PATH=.env.local node --import tsx prisma/seed.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cledson96/lanchonete.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Cledson96/lanchonete/issues"
  },
  "homepage": "https://github.com/Cledson96/lanchonete#readme",
  "engines": {
    "node": ">=20"
  },
  "prisma": {
    "seed": "DOTENV_CONFIG_PATH=.env.local node --import tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bcryptjs": "^3.0.2",
    "jose": "^6.1.0",
    "next": "16.2.2",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "swagger-ui-react": "^5.32.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/swagger-ui-react": "^5.18.0",
    "dotenv": "^17.4.0",
    "eslint": "^9.38.0",
    "eslint-config-next": "16.2.2",
    "prisma": "^7.6.0",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
