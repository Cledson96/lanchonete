{
  "name": "lanchonete",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma da lanchonete",
  "scripts": {
    "dev": "next dev --webpack",
    "dev:whatsapp-worker": "node --import tsx whatsapp-worker/src/server.ts",
    "build": "next build",
    "start": "next start",
    "start:whatsapp-worker": "node --import tsx whatsapp-worker/src/server.ts",
    "lint": "eslint src prisma.config.ts prisma/seed.ts next.config.ts eslint.config.mjs --max-warnings=0",
    "typecheck": "next typegen && tsc --noEmit",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "audit:prod:full": "npm audit --omit=dev",
    "prisma:format": "DOTENV_CONFIG_PATH=.env.local prisma format --schema=prisma/schema.prisma",
    "prisma:validate": "DOTENV_CONFIG_PATH=.env.local prisma validate --schema=prisma/schema.prisma",
    "prisma:generate": "DOTENV_CONFIG_PATH=.env.local prisma generate --schema=prisma/schema.prisma",
    "prisma:seed": "DOTENV_CONFIG_PATH=.env.local node --import tsx prisma/seed.ts",
    "db:start": "bash ./scripts/db/start-local-db.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cledson96/lanchonete.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Cledson96/lanchonete/issues"
  },
  "homepage": "https://github.com/Cledson96/lanchonete#readme",
  "engines": {
    "node": ">=20"
  },
  "prisma": {
    "seed": "DOTENV_CONFIG_PATH=.env.local node --import tsx prisma/seed.ts"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "postcss": "^8.5.14"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@cacheable/node-cache": "^3.0.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hapi/boom": "^10.0.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@whiskeysockets/baileys": "^7.0.0-rc10",
    "bcryptjs": "^3.0.2",
    "jose": "^6.2.3",
    "next": "^16.2.4",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "swagger-ui-react": "^5.32.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/swagger-ui-react": "^5.18.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.38.0",
    "eslint-config-next": "^16.2.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
